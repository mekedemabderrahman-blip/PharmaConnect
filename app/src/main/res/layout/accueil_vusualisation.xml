<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7FB">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginTop="10dp"
            android:src="@android:drawable/ic_menu_manage" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:text="Bonjour, Amine 👋"
                android:textSize="12sp"
                android:textColor="#888"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="Ma Pharmacie"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/notification"            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginEnd="10dp"
            android:src="@android:drawable/ic_popup_reminder"/>

        <ImageView
            android:id="@+id/creecompte"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/account_circle_24dp_000000_fill0_wght400_grad0_opsz24__1_"
            android:scaleType="centerCrop"/>
    </LinearLayout>

    <!-- SEARCH BAR -->
    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_below="@id/header"
        android:layout_margin="12dp"
        android:gravity="center_vertical"
        android:padding="10dp">


        <AutoCompleteTextView
            android:id="@+id/searchAuto"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_margin="12dp"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:hint="Rechercher un produit"
            android:inputType="text"
            android:outlineAmbientShadowColor="@color/cardview_dark_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#1F1F1F"
            android:textColorHint="#8A8A8A" />


    </LinearLayout>

    <!-- BANNER -->
    <LinearLayout
        android:id="@+id/banner"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_below="@id/searchBar"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="10dp"
        android:padding="15dp">

        <LinearLayout
            android:layout_width="170dp"
            android:layout_height="168dp"
            android:layout_weight="100"
            android:background="#FFFFFF"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Prenez soin\nde votre santé"
                android:textColor="#000"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:text="Jusqu'à -30% sur une sélection de produits"
                android:textColor="#FF0909"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnDecouvrir"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:layout_marginStart="7dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="#2ECC71"
                android:text="Découvrir"
                android:textColor="#FFF" />
        </LinearLayout>

        <ImageView
            android:id="@+id/image"
            android:layout_width="201dp"
            android:layout_height="166dp"
            android:background="@drawable/local_pharmacy_24dp_000000_fill0_wght400_grad0_opsz24"
            android:scaleType="centerCrop" />
    </LinearLayout>

    <!-- TITLE -->
    <TextView
        android:id="@+id/titleCat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Catégories"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginTop="15dp"
        android:paddingStart="12dp"
        android:layout_below="@id/banner"/>

    <LinearLayout
        android:id="@+id/categories"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:orientation="horizontal"
        android:layout_below="@id/titleCat"
        android:layout_marginTop="10dp"
        android:padding="5dp">

        <!-- Medicaments -->
        <LinearLayout
            android:id="@+id/catMedic"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/medication_24dp_000000_fill0_wght400_grad0_opsz24"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Médicaments"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- Bébé -->
        <LinearLayout
            android:id="@+id/catBebe"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_launcher_foreground"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bébé &amp; Maman"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- Matériel -->
        <LinearLayout
            android:id="@+id/catMateriel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/matriel_background"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Matériel"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- Soins -->
        <LinearLayout
            android:id="@+id/catSoins"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/pill_24dp_000000_fill0_wght700_grad200_opsz24"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Soins"
                android:textSize="10sp"/>
        </LinearLayout>

    </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

            </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerProducts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/titleCat"
        android:layout_marginTop="118dp"
        android:padding="10dp" />

</RelativeLayout>
