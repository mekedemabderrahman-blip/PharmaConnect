<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:layout_width="match_parent"
    android:layout_height="70dp"
    android:orientation="horizontal"
    android:background="#FFFFFF"
    android:elevation="8dp"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <Button
        android:id="@+id/btnAccueil"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:drawableTop="@drawable/home_24dp_000000_fill0_wght400_grad0_opsz24"
        android:text="Accueil"
        android:textSize="12sp"
        android:textColor="#A08F8F"
        android:backgroundTint="@null"
        android:background="@android:color/transparent"
        android:tint="@null"/>

    <Button
        android:id="@+id/btnCarte"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:drawableTop="@drawable/map_24dp_000000_fill0_wght400_grad0_opsz24"
        android:text="Carte"
        android:textSize="12sp"
        android:textColor="#999"
        android:backgroundTint="@null"
        android:background="@android:color/transparent"
        android:tint="@null"/>

    <Button
        android:id="@+id/btnCommande"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:drawableTop="@drawable/document_scanner_24dp_000000_fill0_wght400_grad0_opsz24"
        android:text="Commandes"
        android:textSize="12sp"
        android:textColor="#999"
        android:backgroundTint="@null"
        android:background="@android:color/transparent"
        android:tint="@null"/>

    <Button
        android:id="@+id/btnProfil"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:drawableTop="@drawable/account_circle_24dp_000000_fill0_wght400_grad0_opsz24__1_"
        android:text="Profil"
        android:textSize="12sp"
        android:textColor="#999"
        android:backgroundTint="@null"
        android:background="@android:color/transparent"
        android:tint="@null"/>

</LinearLayout>